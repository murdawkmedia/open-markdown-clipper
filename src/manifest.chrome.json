{
	"manifest_version": 3,
	"default_locale": "en",
	"name": "Open Markdown Clipper",
	"homepage_url": "https://github.com/murdawkmedia/open-markdown-clipper",
	"version": "0.1.0",
	"minimum_chrome_version": "127",
	"description": "Capture web pages as durable Markdown and deliver them to local destinations.",
	"permissions": [
		"activeTab",
		"clipboardWrite",
		"commands",
		"contextMenus",
		"sidePanel",
		"storage",
		"scripting",
		"declarativeNetRequest"
	],
	"host_permissions": [
		"<all_urls>",
		"http://*/*",
		"https://*/*"
	],
	"action": {
		"default_popup": "popup.html"
	},
	"side_panel": {
		"default_path": "side-panel.html"
	},
	"options_ui": {
		"page": "settings.html",
		"open_in_tab": true
	},
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": ["http://*/*", "https://*/*"],
			"js": ["browser-polyfill.min.js", "content.js"]
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["reader.css", "browser-polyfill.min.js", "style.css", "flatten-shadow-dom.js", "highlighter.css", "icons/icon16.png"],
			"extension_ids": ["*"],
			"matches": [ "*://*/*" ]
		}
	],
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'"
	},
	"commands": {
		"_execute_action": {
			"suggested_key": {
				"default": "Alt+Shift+M",
				"mac": "Alt+Shift+M"
			},
			"description": "__MSG_commandOpenClipper__"
		},
		"quick_clip": {
			"suggested_key": {
				"default": "Alt+Shift+O",
				"mac": "Alt+Shift+O"
			},
			"description": "__MSG_commandQuickClip__"
		},
		"toggle_highlighter": {
			"suggested_key": {
				"default": "Alt+Shift+H",
				"mac": "Alt+Shift+H"
			},
			"description": "__MSG_commandToggleHighlighter__"
		},
		"toggle_reader": {
			"suggested_key": {
				"default": "Alt+Shift+R",
				"mac": "Alt+Shift+R"
			},
			"description": "__MSG_commandToggleReader__"
		}
	}
}
