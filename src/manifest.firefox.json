{
	"manifest_version": 3,
	"default_locale": "en",
	"name": "Open Markdown Clipper",
	"homepage_url": "https://github.com/murdawkmedia/open-markdown-clipper",
	"version": "0.1.0",
	"description": "Capture web pages as durable Markdown and deliver them to local destinations.",
	"permissions": [
		"activeTab",
		"clipboardWrite",
		"contextMenus",
		"storage",
		"scripting",
		"webRequest",
		"webRequestBlocking"
	],
	"host_permissions": [
		"<all_urls>",
		"http://*/*",
		"https://*/*"
	],
	"optional_host_permissions": [
		"<all_urls>"
	],
	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		}
	},
	"options_ui": {
		"page": "settings.html",
		"open_in_tab": true
	},
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"background": {
		"scripts": ["background.js"]
	},
	"content_scripts": [
		{
			"matches": ["http://*/*", "https://*/*"],
			"js": ["browser-polyfill.min.js", "content.js"]
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["reader.css", "browser-polyfill.min.js", "style.css", "flatten-shadow-dom.js", "highlighter.css", "icons/icon16.png"],
			"extension_ids": ["*"],
   			"matches": [ "*://*/*" ]
		}
	],
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'"
	},
	"commands": {
		"_execute_action": {
			"suggested_key": {
				"default": "Alt+Shift+M",
				"mac": "Alt+Shift+M"
			},
			"description": "__MSG_commandOpenClipper__"
		},
		"quick_clip": {
			"suggested_key": {
				"default": "Alt+Shift+O",
				"mac": "Alt+Shift+O"
			},
			"description": "__MSG_commandQuickClip__"
		},
		"toggle_highlighter": {
			"suggested_key": {
				"default": "Alt+Shift+H",
				"mac": "Alt+Shift+H"
			},
			"description": "__MSG_commandToggleHighlighter__"
		},
		"toggle_reader": {
			"suggested_key": {
				"default": "Alt+Shift+R",
				"mac": "Alt+Shift+R"
			},
			"description": "__MSG_commandToggleReader__"
		}
	},
	"browser_specific_settings": {
		"gecko": {
			"id": "open-markdown-clipper@murdawk.media",
			"strict_min_version": "149.0",
			"data_collection_permissions": {
				"required": ["none"],
				"optional": [
					"authenticationInfo",
					"browsingActivity",
					"websiteContent",
					"websiteActivity"
				]
			}
		},
		"gecko_android": {
			"strict_min_version": "149.0"
		}
	}
}
